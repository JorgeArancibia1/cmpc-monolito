# ─────────────────────────────────────────────────────────────
# CMPC Libros — variables de entorno (copiar a .env)
# Puertos elegidos para no chocar con otros servicios locales.
# ─────────────────────────────────────────────────────────────

# PostgreSQL (docker-compose local)
POSTGRES_USER=cmpc
POSTGRES_PASSWORD=cmpc_secret
POSTGRES_DB=cmpc_libros
POSTGRES_PORT=5434

# Backend
DATABASE_URL="postgresql://cmpc:cmpc_secret@localhost:5434/cmpc_libros?schema=public"
DIRECT_URL="postgresql://cmpc:cmpc_secret@localhost:5434/cmpc_libros?schema=public"
API_PORT=3002
NODE_ENV=development

JWT_ACCESS_SECRET=cambia-esto-access-secret-largo-y-aleatorio
JWT_REFRESH_SECRET=cambia-esto-refresh-secret-largo-y-aleatorio
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

CORS_ORIGIN=http://localhost:5174

# Cloudinary (carga de imágenes) — opcional en local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend
# En local apunta directo a la API. En Vercel omitir VITE_API_URL para usar el proxy /api.
VITE_API_URL=http://localhost:3002
